.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 36rpx;
  background: rgba(44, 41, 37, 0.28);
  box-sizing: border-box;
}

.modal {
  width: 100%;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
}

.modal-message {
  margin-top: 18rpx;
  color: #6d6257;
  font-size: 26rpx;
  line-height: 1.7;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}
