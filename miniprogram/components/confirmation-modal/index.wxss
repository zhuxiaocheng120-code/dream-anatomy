.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 36rpx;
  background: rgba(48, 42, 35, 0.34);
  box-sizing: border-box;
}

.modal {
  width: 100%;
  background: linear-gradient(180deg, rgba(255, 253, 246, 0.98), rgba(255, 247, 232, 0.96));
}

.modal-title {
  color: #302a23;
  font-family: "Songti SC", "Noto Serif CJK SC", "Source Han Serif SC", serif;
  font-size: 36rpx;
  font-weight: 700;
}

.modal-message {
  margin-top: 18rpx;
  padding-left: 18rpx;
  border-left: 4rpx solid rgba(137, 72, 72, 0.24);
  color: #6d6358;
  font-size: 26rpx;
  line-height: 1.7;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}
