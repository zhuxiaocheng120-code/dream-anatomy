page {
  min-height: 100vh;
  background: #f7f2ea;
  color: #2c2925;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 48rpx 36rpx 72rpx;
  box-sizing: border-box;
}

.eyebrow {
  color: #8b7764;
  font-size: 24rpx;
  letter-spacing: 0;
}

.title {
  margin-top: 16rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 600;
}

.subtitle {
  margin-top: 18rpx;
  color: #6d6257;
  font-size: 28rpx;
  line-height: 1.7;
}

.section {
  margin-top: 44rpx;
}

.card {
  padding: 32rpx;
  border: 1rpx solid rgba(78, 63, 49, 0.14);
  border-radius: 18rpx;
  background: rgba(255, 252, 246, 0.82);
  box-shadow: 0 20rpx 56rpx rgba(63, 49, 37, 0.08);
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #44382f;
  color: #fffaf1;
  font-size: 28rpx;
  border: 0;
}

.button.secondary {
  background: rgba(68, 56, 47, 0.08);
  color: #44382f;
}

.button.disabled {
  background: rgba(68, 56, 47, 0.1);
  color: #9c8d80;
}

.tag {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(139, 119, 100, 0.12);
  color: #7a6756;
  font-size: 22rpx;
}

.muted {
  color: #81756a;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.input {
  width: 100%;
  min-height: 260rpx;
  padding: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(78, 63, 49, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 252, 246, 0.86);
  color: #2c2925;
  font-size: 28rpx;
  line-height: 1.7;
}

.small {
  font-size: 24rpx;
  line-height: 1.6;
}
