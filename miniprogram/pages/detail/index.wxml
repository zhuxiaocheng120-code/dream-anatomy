<view class="page">
  <view class="page-hero detail-hero">
    <view class="page-hero-content">
      <view class="eyebrow">梦境详情</view>
      <view class="title">{{record.analysisType || '本机梦境'}}</view>
      <view class="subtitle">手稿记录 · {{displayDate}}</view>
    </view>
    <view class="corner-lines" aria-hidden="true" data-visual="detail-manuscript"></view>
  </view>

  <error-state message="{{errorMessage}}"></error-state>

  <view wx:if="{{record}}" class="section manuscript-panel stack">
    <view>
      <view class="eyebrow">梦境原文</view>
      <view class="long-text-safe">{{record.dreamText}}</view>
    </view>
    <view>
      <view class="eyebrow">AI 分析</view>
      <view class="long-text-safe">{{record.reportContent.analysis.coreInterpretation || record.reportContent.analysis.dreamSummary}}</view>
    </view>
  </view>

  <result-card wx:if="{{resultCard}}" card="{{resultCard}}"></result-card>
  <view wx:elif="{{record}}" class="section card small muted">梦境画像暂未生成。</view>

  <button wx:if="{{record}}" class="button danger section" bindtap="showDeleteConfirm">删除这条梦境</button>
  <confirmation-modal
    visible="{{confirmVisible}}"
    title="删除这条梦境"
    message="这会从本机删除该梦境记录，操作不可恢复。"
    confirmText="确认删除"
    bind:cancel="hideDeleteConfirm"
    bind:confirm="deleteRecord"
  />
</view>
