<view class="page">
  <view class="page-hero profile-hero">
    <view class="page-hero-content">
      <view class="eyebrow">Dream Anatomy</view>
      <view class="title" wx:if="{{!authState.authenticated}}">游客模式</view>
      <view class="title" wx:else>微信身份已建立</view>
      <view class="subtitle" wx:if="{{!authState.authenticated}}">当前梦境仅保存在本机。你也可以使用微信身份继续，为后续云端同步做准备。</view>
      <view class="subtitle" wx:else>当前身份可以用于后续云端同步。现阶段梦境仍只保存在本机。</view>
    </view>
    <view class="identity-seal identity-seal-cloud" aria-hidden="true" data-visual="profile-seal">
      <view class="mini-cloud-outline-mark archive-cloud-mark profile-cloud-mark">
        <image class="mini-cloud-outline-layer mini-cloud-outline-base" src="/assets/brand/mini-cloud-outline-base.svg" mode="aspectFit"></image>
        <image class="mini-cloud-outline-layer mini-cloud-outline-flow mini-cloud-outline-flow-0" src="/assets/brand/mini-cloud-outline-flow-0.svg" mode="aspectFit"></image>
        <image class="mini-cloud-outline-layer mini-cloud-outline-flow mini-cloud-outline-flow-1" src="/assets/brand/mini-cloud-outline-flow-1.svg" mode="aspectFit"></image>
        <image class="mini-cloud-outline-layer mini-cloud-outline-flow mini-cloud-outline-flow-2" src="/assets/brand/mini-cloud-outline-flow-2.svg" mode="aspectFit"></image>
        <image class="mini-cloud-outline-layer mini-cloud-outline-flow mini-cloud-outline-flow-3" src="/assets/brand/mini-cloud-outline-flow-3.svg" mode="aspectFit"></image>
        <image class="mini-cloud-outline-layer mini-cloud-outline-flow mini-cloud-outline-flow-4" src="/assets/brand/mini-cloud-outline-flow-4.svg" mode="aspectFit"></image>
        <image class="mini-cloud-outline-layer mini-cloud-outline-flow mini-cloud-outline-flow-5" src="/assets/brand/mini-cloud-outline-flow-5.svg" mode="aspectFit"></image>
      </view>
      <view class="identity-seal-label">{{authState.authenticated ? '微信身份档案' : '本机游客档案'}}</view>
    </view>
  </view>
  <view class="section card profile-card">
    <view>账户状态：{{authState.authenticated ? '微信身份已建立' : '游客'}}</view>
    <view class="small muted">云同步：暂未开启</view>
    <view class="small muted" wx:if="{{authState.authenticated && expiresAt}}">登录状态有效期：{{expiresAt}}</view>
    <view class="small muted" wx:if="{{authState.authenticated && !expiresAt}}">登录状态正常</view>
    <view class="small muted">不会显示或保存微信头像、昵称、手机号或内部身份标识。</view>
  </view>
  <view class="section card profile-action-card">
    <button
      wx:if="{{!authState.authenticated}}"
      class="button"
      loading="{{isBusy}}"
      disabled="{{isBusy}}"
      bindtap="handleWechatLogin"
    >使用微信身份继续</button>
    <button
      wx:else
      class="button secondary-button"
      loading="{{isBusy}}"
      disabled="{{isBusy}}"
      bindtap="handleWechatLogout"
    >退出当前身份</button>
    <view class="small muted profile-status" wx:if="{{statusMessage}}">{{statusMessage}}</view>
  </view>
  <button class="button section" bindtap="goPrivacy">隐私与数据</button>
</view>
